<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="DB file.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure pragmas query" current="2"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="1260"/><column_width id="4" width="0"/><expanded_item id="0" parent="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="SalesData" custom_title="0" dock_id="1" table="4,9:mainSalesData"/><dock_state state="000000ff00000000fd00000001000000020000000000000000fc0100000001fb000000160064006f0063006b00420072006f00770073006500310100000000ffffffff0000011e00ffffff000000000000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings><table schema="main" name="SalesData" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="87"/><column index="2" value="87"/><column index="3" value="84"/><column index="4" value="73"/><column index="5" value="84"/><column index="6" value="80"/><column index="7" value="91"/><column index="8" value="89"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1">--TOTAL ORDERS
SELECT COUNT(OrderNumber) AS Total_Orders
FROM SalesData;
--ORDERS BY YEAR
SELECT substr(OrderDate,-4) AS Year,
       COUNT(OrderNumber) AS Total_Orders
FROM SalesData
GROUP BY Year
ORDER BY Year;
-- order by TerritoryKey
select TerritoryKey,COUNT(OrderNumber) AS Total_Orders
FROM SalesData
GROUP BY TerritoryKey
ORDER BY Total_Orders DESC;
--Top 10 Products
SELECT ProductKey,
       COUNT(OrderNumber) AS Total_Orders
FROM SalesData
GROUP BY ProductKey
ORDER BY Total_Orders DESC
LIMIT 10;
--Top 10 Customers
SELECT CustomerKey,
       COUNT(OrderNumber) AS Total_Orders
FROM SalesData
GROUP BY CustomerKey
ORDER BY Total_Orders DESC
LIMIT 10;
--Total Quantity Sold by Product
SELECT ProductKey,
       SUM(OrderQuantity) AS Total_Quantity
FROM SalesData
GROUP BY ProductKey
ORDER BY Total_Quantity DESC
LIMIT 10;
--Average Order Quantity
SELECT AVG(OrderQuantity) AS Average_Quantity
FROM SalesData;
</sql><current_tab id="0"/></tab_sql></sqlb_project>
